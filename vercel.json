{
  "rewrites": [
    {
      "source": "/subjects/:path*",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://lexnotes-waitlist.vercel.app",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "lexnotes-seven.vercel.app"
        }
      ]
    }
  ]
}
